          "id": "photogimp",
          "label": "PhotoGIMP",
          "desc": "Конфигурация GIMP в стиле Photoshop",
          "source": {
            "label": "GitHub",
            "cmd": [
              "bash",
              "-c",
              "set -e; REAL_USER=${SUDO_USER:-$(getent passwd \"${PKEXEC_UID:-0}\" | cut -d: -f1)}; HOME_DIR=$(getent passwd $REAL_USER | cut -d: -f6); TMP=$(mktemp -d); sudo -u $REAL_USER git clone --depth=1 https://github.com/Diolinux/PhotoGIMP.git \"$TMP/PhotoGIMP\"; SRC=\"$TMP/PhotoGIMP/.config/GIMP/3.0\"; for GIMP_DIR in \"$HOME_DIR/.var/app/org.gimp.GIMP/config/GIMP/3.0\" \"$HOME_DIR/.config/GIMP/3.0\"; do sudo -u $REAL_USER mkdir -p \"$GIMP_DIR\" && sudo -u $REAL_USER cp -r \"$SRC/.\" \"$GIMP_DIR/\"; done; sudo -u $REAL_USER touch \"$HOME_DIR/.config/photogimp-installed\"; rm -rf \"$TMP\""
            ],
            "check": [
              "any_of",
              [
                [
                  "path",
                  "~/.config/photogimp-installed"
                ],
                [
                  "desktop_keyword",
                  "photogimp"
                ]
              ]
            ]
          }
        },
