        {
          "id": "context7_mcp",
          "label": "context7 MCP сервер",
          "desc": "Подключает Context7 к Cursor (MCP, правило и skill в ~/.cursor/). В терминале откроется браузер для входа; в чате: «use context7 …». Требуются Node.js/npx и сеть",
          "source": {
            "label": "Скрипт",
            "cmd": [
              "bash",
              "-c",
              "if [ -z \"$PKEXEC_UID\" ]; then echo \"Ошибка: запускайте из графической сессии ALT Booster\"; exit 1; fi; U=$(getent passwd \"$PKEXEC_UID\" | cut -d: -f1); H=$(getent passwd \"$PKEXEC_UID\" | cut -d: -f6); runuser -u \"$U\" -- bash -lc \"cd \\\"$H\\\" && npx -y ctx7@0.3.6 setup --cursor\""
            ],
            "check": [
              "path",
